{
  "expo": {
    "name": "Fluxy Logistique",
    "slug": "fluxy-logistique",
    "version": "1.0.8",
    "owner": "axenterprises",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fluxylogistique",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "extra": {
      "backendUrl": "https://fluxy-express.preview.emergentagent.com",
      "eas": {
        "projectId": "f3261443-ae67-494f-a854-cd498bee282b"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/f3261443-ae67-494f-a854-cd498bee282b"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fluxy.logistique",
      "infoPlist": {
        "NSCameraUsageDescription": "Pour prendre des photos de livraison",
        "NSPhotoLibraryUsageDescription": "Pour sélectionner des documents"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.fluxylogistique.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "androidStatusBar": {
      "backgroundColor": "#2563EB",
      "barStyle": "light-content"
    },
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#2563EB",
      "androidMode": "default",
      "androidCollapsedTitle": "Fluxy Logistique"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "36.0.0",
            "kotlinVersion": "1.9.24",
            "enableProguardInReleaseBuilds": false,
            "newArchEnabled": false
          },
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2563EB"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2563EB",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
